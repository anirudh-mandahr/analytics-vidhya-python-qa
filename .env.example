# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostgreSQL with the pgvector extension enabled.
# Supabase: Project Settings -> Database. Use the pooled URL (port 6543) for the
# API, and the DIRECT URL (port 5432) when running ingestion/ingest.py.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# LLM provider. "groq" uses Groq natively; "openai" uses any OpenAI-compatible
# endpoint (OpenRouter, Together, OpenAI, ...). Swapping providers is config only.
LLM_PROVIDER=groq

# --- if LLM_PROVIDER=groq ---  free key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# --- if LLM_PROVIDER=openai --- e.g. OpenRouter:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-v1-your_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# ---------------------------------------------------------------------------
# Optional overrides (defaults shown)
# ---------------------------------------------------------------------------
# LLM_MODEL=llama-3.3-70b-versatile
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# TOP_K=5
# MIN_SIMILARITY=0.45
# MAX_CONTEXT_CHARS_PER_DOC=2500
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=1024
# LLM_TIMEOUT_S=30
